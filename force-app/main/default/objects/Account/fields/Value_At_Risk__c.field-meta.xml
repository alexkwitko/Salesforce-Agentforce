<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Value_At_Risk__c</fullName>
    <label>Value at Risk</label>
    <type>Currency</type>
    <precision>16</precision>
    <scale>2</scale>
    <formula>NULLVALUE(Churn_Score__c,0) * NULLVALUE(Predicted_LTV__c,0)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <description>Expected dollars lost if the customer churns = churn x predicted LTV.</description>
</CustomField>
