<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <description>When a cart is marked Abandoned and not yet routed, dedupe by email and create an inside-sales Lead (or link to a known customer).</description>
    <environments>Default</environments>
    <interviewLabel>Abandoned Cart to Lead {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Abandoned Cart to Lead</label>
    <processType>AutoLaunchedFlow</processType>
    <actionCalls>
        <name>Process_Abandoned_Cart</name>
        <label>Process Abandoned Cart</label>
        <locationX>176</locationX>
        <locationY>288</locationY>
        <actionName>AbandonedCartService</actionName>
        <actionType>apex</actionType>
        <flowTransactionModel>CurrentTransaction</flowTransactionModel>
        <inputParameters>
            <name>cartId</name>
            <value><elementReference>$Record.Id</elementReference></value>
        </inputParameters>
        <nameSegment>AbandonedCartService</nameSegment>
    </actionCalls>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector><targetReference>Process_Abandoned_Cart</targetReference></connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Status__c</field>
            <operator>EqualTo</operator>
            <value><stringValue>Abandoned</stringValue></value>
        </filters>
        <filters>
            <field>Lead__c</field>
            <operator>IsNull</operator>
            <value><booleanValue>true</booleanValue></value>
        </filters>
        <filters>
            <field>Customer__c</field>
            <operator>IsNull</operator>
            <value><booleanValue>true</booleanValue></value>
        </filters>
        <object>Cart__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
