<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <description>Headless self-service automation: when an e-commerce Order is activated, enqueue the post-purchase offer (recommendation + coupon + email). Consent is enforced inside the offer logic.</description>
    <environments>Default</environments>
    <interviewLabel>Auto Post-Purchase Offer {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Auto Post-Purchase Offer</label>
    <processType>AutoLaunchedFlow</processType>
    <actionCalls>
        <name>Enqueue_Offer</name>
        <label>Enqueue Post-Purchase Offer</label>
        <locationX>176</locationX>
        <locationY>278</locationY>
        <actionName>PostPurchaseAutoOffer</actionName>
        <actionType>apex</actionType>
        <flowTransactionModel>CurrentTransaction</flowTransactionModel>
        <inputParameters>
            <name>orderId</name>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputParameters>
        <nameSegment>PostPurchaseAutoOffer</nameSegment>
    </actionCalls>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Enqueue_Offer</targetReference>
        </connector>
        <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Status</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Activated</stringValue>
            </value>
        </filters>
        <filters>
            <field>Source__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Ecommerce</stringValue>
            </value>
        </filters>
        <object>Order</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Draft</status>
</Flow>
