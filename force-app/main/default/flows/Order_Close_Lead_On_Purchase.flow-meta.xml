<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <description>When ANY Order is created/updated for a Person Account, close the shopper's open leads as converted-by-purchase (single-writer lead close, declarative). Complements WooOrderService so chat/manual/Woo orders all close the lead.</description>
    <environments>Default</environments>
    <interviewLabel>Order Close Lead On Purchase {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Order Close Lead On Purchase</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value><stringValue>LightningFlowBuilder</stringValue></value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <actionCalls>
        <name>Close_Leads_For_Purchase</name>
        <label>Close Leads For Purchase</label>
        <locationX>176</locationX>
        <locationY>288</locationY>
        <actionName>LeadLifecycleService</actionName>
        <actionType>apex</actionType>
        <flowTransactionModel>CurrentTransaction</flowTransactionModel>
        <inputParameters>
            <name>email</name>
            <value><elementReference>$Record.Account.PersonEmail</elementReference></value>
        </inputParameters>
        <inputParameters>
            <name>accountId</name>
            <value><elementReference>$Record.AccountId</elementReference></value>
        </inputParameters>
        <inputParameters>
            <name>orderId</name>
            <value><elementReference>$Record.Id</elementReference></value>
        </inputParameters>
        <nameSegment>LeadLifecycleService</nameSegment>
    </actionCalls>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Close_Leads_For_Purchase</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>AccountId</field>
            <operator>IsNull</operator>
            <value><booleanValue>false</booleanValue></value>
        </filters>
        <object>Order</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
