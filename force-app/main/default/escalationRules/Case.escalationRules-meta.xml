<?xml version="1.0" encoding="UTF-8"?>
<EscalationRules xmlns="http://soap.sforce.com/2006/04/metadata">
    <escalationRule>
        <fullName>Standard</fullName>
        <active>true</active>
        <!-- High-priority cases unresolved past 1 business hour route to the Kwitko Escalations queue. -->
        <ruleEntry>
            <businessHoursSource>Static</businessHoursSource>
            <businessHours>Default</businessHours>
            <criteriaItems>
                <field>Case.Priority</field>
                <operation>equals</operation>
                <value>High</value>
            </criteriaItems>
            <criteriaItems>
                <field>Case.IsClosed</field>
                <operation>equals</operation>
                <value>false</value>
            </criteriaItems>
            <escalationAction>
                <assignedTo>Kwitko_Escalations</assignedTo>
                <assignedToType>Queue</assignedToType>
                <minutesToEscalation>60</minutesToEscalation>
                <notifyCaseOwner>true</notifyCaseOwner>
                <notifyToTemplate>unfiled$public/SupportEscalatedCaseNotification</notifyToTemplate>
            </escalationAction>
            <escalationStartTime>CaseCreation</escalationStartTime>
        </ruleEntry>
        <!-- Explicit "Escalation" category cases route to the queue faster (30 min). -->
        <ruleEntry>
            <businessHoursSource>Static</businessHoursSource>
            <businessHours>Default</businessHours>
            <criteriaItems>
                <field>Case.Category__c</field>
                <operation>equals</operation>
                <value>Escalation</value>
            </criteriaItems>
            <criteriaItems>
                <field>Case.IsClosed</field>
                <operation>equals</operation>
                <value>false</value>
            </criteriaItems>
            <escalationAction>
                <assignedTo>Kwitko_Escalations</assignedTo>
                <assignedToType>Queue</assignedToType>
                <minutesToEscalation>30</minutesToEscalation>
                <notifyCaseOwner>true</notifyCaseOwner>
                <notifyToTemplate>unfiled$public/SupportEscalatedCaseNotification</notifyToTemplate>
            </escalationAction>
            <escalationStartTime>CaseCreation</escalationStartTime>
        </ruleEntry>
    </escalationRule>
</EscalationRules>
