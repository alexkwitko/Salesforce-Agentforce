@isTest
private class PostPurchaseSweepTest {
    private class WooMock implements HttpCalloutMock {
        public HttpResponse respond(HttpRequest req) {
            HttpResponse r = new HttpResponse(); r.setStatusCode(201); r.setBody('{"id":1,"code":"x"}'); return r;
        }
    }

    @testSetup
    static void setup() {
        Id paRt = [SELECT Id FROM RecordType WHERE SObjectType='Account' AND IsPersonType=true LIMIT 1].Id;
        Account pa = new Account(FirstName='Sweep', LastName='Buyer', PersonEmail='sweep@example.com',
            Email_Consent__c=true, RecordTypeId=paRt);
        insert pa;
        Product2 b = new Product2(Name='Sweep Bought', Family='Single-Origin', IsActive=true,
            StockKeepingUnit='S-B', Stock_On_Hand__c=10, Woo_Product_Id__c='3001');
        Product2 rcd = new Product2(Name='Sweep Rec', Family='Single-Origin', IsActive=true,
            StockKeepingUnit='S-R', Stock_On_Hand__c=99, Woo_Product_Id__c='3002');
        insert new List<Product2>{ b, rcd };
        Id pb = Test.getStandardPricebookId();
        PricebookEntry pbe = new PricebookEntry(Pricebook2Id=pb, Product2Id=b.Id, UnitPrice=20, IsActive=true);
        insert pbe;
        Order o = new Order(AccountId=pa.Id, EffectiveDate=Date.today(), Status='Draft',
            Pricebook2Id=pb, Woo_Order_Id__c='S-1', Source__c='Ecommerce');
        insert o;
        insert new OrderItem(OrderId=o.Id, PricebookEntryId=pbe.Id, Product2Id=b.Id, Quantity=1, UnitPrice=20);
        update new Order(Id=o.Id, Status='Activated', Fulfillment_Status__c='Shipped', Woo_Status__c='completed'); // valid path: Draft -> Activated
    }

    @isTest
    static void testSweepGeneratesOffers() {
        Order o = [SELECT Id FROM Order WHERE Woo_Order_Id__c='S-1' LIMIT 1];

        Test.setMock(HttpCalloutMock.class, new WooMock());
        Test.startTest();
        Integer n = PostPurchaseSweep.sweep();
        Test.stopTest();
        System.assertEquals(1, n, 'one eligible order swept');
        System.assertEquals(1, [SELECT count() FROM Coupon__c WHERE Order__c=:o.Id], 'offer generated by sweep');
    }
}
