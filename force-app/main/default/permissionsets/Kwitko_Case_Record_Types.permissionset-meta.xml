<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Kwitko Case Record Types</label>
    <description>Grants visibility to the Kwitko Case record types (Order Issue, Return/Refund, Billing, General) for human service users.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <applicationVisibilities>
        <application>Kwitko_Service_Console</application>
        <visible>true</visible>
    </applicationVisibilities>
    <recordTypeVisibilities>
        <recordType>Case.Order_Issue</recordType>
        <visible>true</visible>
    </recordTypeVisibilities>
    <recordTypeVisibilities>
        <recordType>Case.Return_Refund</recordType>
        <visible>true</visible>
    </recordTypeVisibilities>
    <recordTypeVisibilities>
        <recordType>Case.Billing</recordType>
        <visible>true</visible>
    </recordTypeVisibilities>
    <recordTypeVisibilities>
        <recordType>Case.General</recordType>
        <visible>true</visible>
    </recordTypeVisibilities>
</PermissionSet>
