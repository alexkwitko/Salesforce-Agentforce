            <localDeveloperName>provision</localDeveloperName>
            <masterLabel>Provision Subscription</masterLabel>
            <progressIndicatorMessage>Setting up your subscription...</progressIndicatorMessage>
        </localActions>
        <localActions>
            <fullName>cancel_179fj000002WDgx</fullName>
