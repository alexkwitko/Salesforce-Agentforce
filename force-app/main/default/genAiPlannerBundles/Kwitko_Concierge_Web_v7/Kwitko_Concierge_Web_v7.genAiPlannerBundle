        <localActions>
            <fullName>save_preferences_179fj000002LM4P</fullName>
            <description>Persist a stated coffee preference (a like, a dislike, roast level, format, or brew method) to the customer&apos;s profile and unified profile. Call this WHENEVER the shopper states or implies a preference, especially a dislike or a rejection of a recommendation.</description>
            <developerName>save_preferences_179fj000002LM4P</developerName>
            <invocationTarget>CustomerPreferenceService</invocationTarget>
            <invocationTargetType>apex</invocationTargetType>
            <isConfirmationRequired>false</isConfirmationRequired>
            <isIncludeInProgressIndicator>true</isIncludeInProgressIndicator>
            <localDeveloperName>save_preferences</localDeveloperName>
            <masterLabel>Save Customer Preferences</masterLabel>
            <progressIndicatorMessage>Updating your preferences...</progressIndicatorMessage>
        </localActions>
        <localActions>
            <fullName>lookup_customer_179fj000002LM4P</fullName>
            <description>Look up whether this email is a returning customer and summarize their history.</description>
            <developerName>lookup_customer_179fj000002LM4P</developerName>
            <invocationTarget>CustomerLookupService</invocationTarget>
            <invocationTargetType>apex</invocationTargetType>
            <isConfirmationRequired>false</isConfirmationRequired>
            <isIncludeInProgressIndicator>true</isIncludeInProgressIndicator>
            <localDeveloperName>lookup_customer</localDeveloperName>
            <masterLabel>Lookup Customer</masterLabel>
            <progressIndicatorMessage>Checking if we know you...</progressIndicatorMessage>
        </localActions>
        <localActions>
            <fullName>issue_coupon_179fj000002LM4P</fullName>
            <description>Create a REAL, single-use, personalized discount coupon for this shopper in the store and return its code. Call this once after recommending, before add_to_cart, so the discount can be auto-applied.</description>
            <developerName>issue_coupon_179fj000002LM4P</developerName>
            <invocationTarget>CouponService</invocationTarget>
            <invocationTargetType>apex</invocationTargetType>
            <isConfirmationRequired>false</isConfirmationRequired>
            <isIncludeInProgressIndicator>true</isIncludeInProgressIndicator>
            <localDeveloperName>issue_coupon</localDeveloperName>
            <masterLabel>Issue Personalized Coupon</masterLabel>
            <progressIndicatorMessage>Creating your personal discount...</progressIndicatorMessage>
        </localActions>
        <localActions>
            <fullName>capture_lead_179fj000002LM4P</fullName>
            <description>Create or update a Website Chat lead with the shopper&apos;s name, email, marketing consent, and interest.</description>
            <developerName>capture_lead_179fj000002LM4P</developerName>
            <invocationTarget>ChatLeadService</invocationTarget>
            <invocationTargetType>apex</invocationTargetType>
            <isConfirmationRequired>false</isConfirmationRequired>
            <isIncludeInProgressIndicator>true</isIncludeInProgressIndicator>
            <localDeveloperName>capture_lead</localDeveloperName>
            <masterLabel>Capture Lead</masterLabel>
            <progressIndicatorMessage>Saving your details...</progressIndicatorMessage>
        </localActions>
        <localActions>
            <fullName>add_to_cart_179fj000002LM4P</fullName>
            <description>Build a REAL working add-to-cart link for the recommended products. Call this when the shopper asks to add items to their cart or check out. You CANNOT add items yourself — this returns a link the shopper clicks to add them.</description>
            <developerName>add_to_cart_179fj000002LM4P</developerName>
            <invocationTarget>CartLinkService</invocationTarget>
            <invocationTargetType>apex</invocationTargetType>
            <isConfirmationRequired>false</isConfirmationRequired>
            <isIncludeInProgressIndicator>true</isIncludeInProgressIndicator>
            <localDeveloperName>add_to_cart</localDeveloperName>
            <masterLabel>Build Add-to-Cart Links</masterLabel>
            <progressIndicatorMessage>Preparing your cart link...</progressIndicatorMessage>
        </localActions>
        <localActions>
            <fullName>build_strategy_179fj000002LM4P</fullName>
