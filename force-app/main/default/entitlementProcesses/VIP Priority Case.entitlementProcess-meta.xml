<?xml version="1.0" encoding="UTF-8"?>
<EntitlementProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <SObjectType>Case</SObjectType>
    <active>true</active>
    <description>Accelerated SLA process for VIP / high-value customers: 1h first response, 4h escalation, 24h resolution.</description>
    <entryStartDateField>Case.CreatedDate</entryStartDateField>
    <exitCriteriaFilterItems>
        <field>Case.IsClosed</field>
        <operation>equals</operation>
        <value>true</value>
    </exitCriteriaFilterItems>
    <milestones>
        <isDisplayedOnLinkedEntity>false</isDisplayedOnLinkedEntity>
        <milestoneName>First Response to Customer</milestoneName>
        <minutesToComplete>60</minutesToComplete>
        <timeTriggers>
            <actions>
                <name>ChangePriorityToHigh</name>
                <type>FieldUpdate</type>
            </actions>
            <timeLength>-15</timeLength>
            <workflowTimeTriggerUnit>Minutes</workflowTimeTriggerUnit>
        </timeTriggers>
        <useCriteriaStartTime>false</useCriteriaStartTime>
    </milestones>
    <milestones>
        <isDisplayedOnLinkedEntity>false</isDisplayedOnLinkedEntity>
        <milestoneName>Escalate Case</milestoneName>
        <minutesToComplete>240</minutesToComplete>
        <timeTriggers>
            <actions>
                <name>AutoEscalateCase</name>
                <type>FieldUpdate</type>
            </actions>
            <timeLength>0</timeLength>
            <workflowTimeTriggerUnit>Minutes</workflowTimeTriggerUnit>
        </timeTriggers>
        <useCriteriaStartTime>false</useCriteriaStartTime>
    </milestones>
    <milestones>
        <isDisplayedOnLinkedEntity>false</isDisplayedOnLinkedEntity>
        <milestoneName>Close Case</milestoneName>
        <minutesToComplete>1440</minutesToComplete>
        <useCriteriaStartTime>false</useCriteriaStartTime>
    </milestones>
</EntitlementProcess>
